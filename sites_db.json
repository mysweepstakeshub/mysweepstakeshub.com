Step 2: Update the Homepage (index.html)
Now we update your layout to look like a Premium Review Site. This builds "Trust," which is why people will click your links.

Open index.html on GitHub.

Delete everything and paste this "Directory Card" code:

HTML
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>MySweepstakesHub - The Web's Ultimate Directory</title>
    <style>
        body { font-family: 'Segoe UI', Arial, sans-serif; margin: 0; background: #f4f7f6; color: #333; }
        header { background: #000080; color: white; padding: 40px 20px; text-align: center; }
        #container { max-width: 900px; margin: -30px auto 50px; padding: 0 20px; }
        .site-card { 
            background: white; border-radius: 12px; padding: 25px; margin-bottom: 25px;
            display: flex; gap: 20px; box-shadow: 0 4px 15px rgba(0,0,0,0.1);
            border-left: 6px solid #28a745; position: relative;
        }
        .rating-badge { position: absolute; top: 15px; right: 20px; background: #ffc107; padding: 5px 12px; border-radius: 20px; font-weight: bold; }
        .info-sec { flex: 1; }
        .site-title { font-size: 22px; font-weight: bold; color: #000080; margin-bottom: 10px; }
        .pros-list { display: flex; gap: 10px; flex-wrap: wrap; margin: 10px 0; }
        .pro-tag { background: #e8f5e9; color: #2e7d32; padding: 4px 10px; border-radius: 4px; font-size: 11px; font-weight: bold; }
        .btn-visit { background: #28a745; color: white; padding: 15px 30px; border-radius: 8px; text-decoration: none; font-weight: bold; display: inline-block; }
    </style>
</head>
<body>

<header>
    <h1>MySweepstakesHub.com</h1>
    <p>Top-Rated Giveaway & Contest Sites for 2026</p>
</header>

<div id="container">
    <div id="directory-list">Loading the best sites...</div>
</div>

<script>
    fetch('sites_db.json')
        .then(res => res.json())
        .then(data => {
            const list = document.getElementById('directory-list');
            list.innerHTML = data.map(site => `
                <div class="site-card">
                    <div class="rating-badge">${site.rating} ★</div>
                    <div class="info-sec">
                        <div class="site-title">${site.name}</div>
                        <p>${site.description}</p>
                        <div class="pros-list">
                            ${site.pros.map(pro => `<span class="pro-tag">✓ ${pro}</span>`).join('')}
                        </div>
                        <a href="${site.url}" target="_blank" class="btn-visit">Visit Official Site »</a>
                    </div>
                </div>
            `).join('');
        });
</script>
</body>
</html>
